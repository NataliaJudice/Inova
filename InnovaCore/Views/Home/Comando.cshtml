@model InnovaCore.ViewModels.ViewModelDashboard
@using System.Globalization

@{
    ViewData["Title"] = "Terminal de Comando";
    Layout = "_Layout";

    // Materialização segura da lista para uso no HTML e no JavaScript
    var listaSetores = Model.VwQtdePorSetor as IEnumerable<InnovaCore.Domain.Entities.VwQtdePorSetor>
                       ?? new List<InnovaCore.Domain.Entities.VwQtdePorSetor>();

    // 1. CÁLCULO MATEMÁTICO DINÂMICO DA TAXA DE CONCLUSÃO GLOBAL
    double totalTarefas = Model.VwDashboardQtde.TotalDeTarefas;
    double resolvidas = Model.VwDashboardQtde.TarefasConcluidas ; // Alinhado com a nomenclatura do seu banco/view
    double taxaConclusao = totalTarefas > 0 ? (resolvidas / totalTarefas) * 100 : 0;
}

<style>
    :root {
        --bg-black: #050505;
        --card-bg: #0d1117;
        --accent-blue: #00e5ff; /* Trocado para o ciano neon padrão do seu sistema */
        --accent-purple: #7000ff; /* Trocado para o roxo neon padrão */
        --accent-green: #00ff9d; /* Verde neon */
        --text-gray: #8b949e;
        --border-muted: #21262d;
    }

    body {
        background-color: var(--bg-black) !important;
        color: #f0f6fc;
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    /* --- ANIMAÇÕES --- */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-card {
        animation: fadeInUp 0.6s ease backwards;
    }

    /* --- LAYOUT --- */
    .dashboard-wrapper {
        padding: 2.5rem 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .dashboard-header h1 {
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 2.2rem;
        animation: fadeInUp 0.5s ease;
    }

    /* --- METRIC CARDS --- */
    .metric-card {
        background: #0d1117;
        border: 1px solid var(--border-muted);
        border-radius: 20px;
        padding: 1.5rem;
        height: 100%;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .metric-card:hover {
            border-color: var(--accent-blue);
            background: #161b22;
            transform: translateY(-5px);
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.1);
        }

    .metric-value {
        font-size: 3rem;
        font-weight: 800;
        line-height: 1;
        margin-top: 0.8rem;
        letter-spacing: -1.5px;
    }

    .icon-box-print {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }

    /* --- CONTAINER DOS GRÁFICOS --- */
    .chart-container-print {
        background: #0d1117;
        border: 1px solid var(--border-muted);
        border-radius: 24px;
        padding: 2rem;
        height: 100%;
        animation: fadeInUp 0.8s ease backwards;
        animation-delay: 0.4s;
    }

    /* SOLUÇÃO PARA O AMONTROAMENTO: Container de rolagem responsivo */
    .chart-scroll-area {
        width: 100%;
        overflow-x: auto; /* Adiciona barra de rolagem horizontal se necessário */
        overflow-y: hidden;
        padding-bottom: 5px;
    }

        .chart-scroll-area::-webkit-scrollbar {
            height: 6px;
        }

        .chart-scroll-area::-webkit-scrollbar-track {
            background: #0d1117;
        }

        .chart-scroll-area::-webkit-scrollbar-thumb {
            background: #21262d;
            border-radius: 10px;
        }

            .chart-scroll-area::-webkit-scrollbar-thumb:hover {
                background: var(--accent-blue);
            }

    .chart-wrapper-inner {
        min-width: 600px; /* Impede que as barras encolham menos do que o ideal */
        height: 280px;
    }

    .label-caps {
        font-size: 0.7rem;
        letter-spacing: 1.5px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-gray);
    }

    .btn-action-main {
        background: #f0f6fc;
        color: #0d1117;
        font-weight: 700;
        font-size: 0.75rem;
        border-radius: 8px;
        padding: 10px 24px;
        border: none;
        transition: transform 0.2s;
        cursor: pointer;
    }

        .btn-action-main:hover {
            transform: scale(1.05);
        }

    /* Centralização e posicionamento do valor interno do Donut */
    .donut-wrapper {
        position: relative;
        width: 200px;
        height: 200px;
        margin: 1.5rem auto;
    }

    .donut-percentage {
        position: absolute;
        top: 53%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }
</style>

<div class="dashboard-wrapper">
    <div class="row align-items-center mb-5">
        <div class="col-md-8">
            <div class="dashboard-header">
                <h1>Painel de Controle</h1>
                <p class="text-secondary small mt-1">Telemetria de performance em tempo real.</p>
            </div>
        </div>
        @* <div class="col-md-4 text-md-end">
            <button class="btn btn-action-main" onclick="window.print()">GERAR RELATÓRIO</button>
        </div> *@
    </div>

    <div class="row g-4 mb-5">
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.1s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(0, 229, 255, 0.1); color: var(--accent-blue);">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="label-caps">Total de Tarefas</div>
                <div class="metric-value text-white">@Model.VwDashboardQtde.TotalDeTarefas</div>
            </div>
        </div>
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.2s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(112, 0, 255, 0.1); color: var(--accent-purple);">
                    <i class="bi bi-clock-fill"></i>
                </div>
                <div class="label-caps" style="color: var(--accent-purple);">Aguardando Resposta</div>
                <div class="metric-value text-white">@Model.VwDashboardQtde.SolicitacoesPendentes</div>
            </div>
        </div>
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.3s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(0, 255, 157, 0.1); color: var(--accent-green);">
                    <i class="bi bi-activity"></i>
                </div>
                <div class="label-caps" style="color: #00ff9d;">Em Andamento</div>
                <div class="metric-value text-white">@Model.VwDashboardQtde.TarefasEmAndamento</div>
            </div>
        </div>
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.4s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(255, 255, 255, 0.05); color: #6e7681;">
                    <i class="bi bi-archive-fill"></i>
                </div>
                <div class="label-caps">A Fazer</div>
                <div class="metric-value" style="color: #6e7681;">@Model.VwDashboardQtde.TarefasAComecar</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="chart-container-print">
                <h5 class="fw-bold mb-4 text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">Propostas por Setor</h5>

                @if (listaSetores.Any())
                {
                    <div class="chart-scroll-area">
                        <div class="chart-wrapper-inner" style="width: @(Math.Max(600, listaSetores.Count() * 70))px;">
                            <canvas id="ctxBarrasSetor"></canvas>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center w-100 py-5">
                        <p class="text-secondary opacity-50 m-0">Aguardando telemetria operacional...</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="chart-container-print text-center">
                <h5 class="fw-bold text-start text-uppercase mb-2" style="font-size: 0.85rem;">Conclusão Global</h5>

                <div class="donut-wrapper">
                    <canvas id="ctxDonutConclusao"></canvas>
                    <div class="donut-percentage">
                        <span class="label-caps" style="font-size: 0.55rem;">TAXA REAL</span>
                        <span style="color: #fff; font-size: 2rem; font-weight: 900; letter-spacing: -1px;">
                            @taxaConclusao.ToString("F1", CultureInfo.InvariantCulture)%
                        </span>
                    </div>
                </div>

                <div class="d-flex justify-content-around mt-2 border-top border-secondary pt-3 mx-2">
                    <small class="text-secondary"><i class="bi bi-circle-fill me-1" style="color:var(--accent-green)"></i> Resolvidas: @Model.VwDashboardQtde.TarefasConcluidas</small>
                    <small class="text-secondary"><i class="bi bi-circle-fill me-1" style="color:#21262d"></i> Restantes: @(totalTarefas - resolvidas)</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        // 2. CONFIGURAÇÃO DO GRÁFICO DE BARRAS (SETOR)
        @if (listaSetores.Any())
        {
            // Serialização limpa dos dados Razor C# para Arrays do JavaScript
            <text>
                const labelsSetores = [@Html.Raw(string.Join(",", listaSetores.Select(x => $"'{System.Web.HttpUtility.JavaScriptStringEncode(x.Nome)}'")))];
                const dadosQuantidades = [@string.Join(",", listaSetores.Select(x => x.QTDE_POR_SETOR ?? 0))];

                const ctxBarras = document.getElementById('ctxBarrasSetor').getContext('2d');
                new Chart(ctxBarras, {
                type: 'bar',
                data: {
                labels: labelsSetores,
                datasets: [{
                label: 'Propostas',
                data: dadosQuantidades,
                backgroundColor: 'rgba(0, 229, 255, 0.85)',
                borderColor: '#00e5ff',
                borderWidth: 1,
                borderRadius: 6,
                barThickness: 28 // Força uma espessura de barra fixa elegante
                }]
                },
                options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                y: {
                grid: { color: 'rgba(255, 255, 255, 0.05)' },
                ticks: { color: '#8b949e', stepSize: 1 }
                },
                x: {
                grid: { display: false },
                ticks: { color: '#8b949e', font: { size: 10 } }
                }
                }
                }
                });
            </text>
        }

        // 3. CONFIGURAÇÃO DO GRÁFICO DONUT DINÂMICO
        const total = @totalTarefas;
        const concluidas = @resolvidas;
        const pendentes = total - concluidas;

        const ctxDonut = document.getElementById('ctxDonutConclusao').getContext('2d');
        new Chart(ctxDonut, {
        type: 'doughnut',
        data: {
        labels: ['Concluídas', 'Pendentes'],
        datasets: [{
        data: [concluidas, total > 0 ? pendentes : 1], // Previne quebra visual se o total for zero
        backgroundColor: [
        '#00ff9d', // Verde neon para tarefas prontas
        total > 0 ? '#1f2937' : '#0d1117' // Cor vazia de fundo
        ],
        borderWidth: 0,
        hoverOffset: 0
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '80%', // Deixa a rosca interna fina e elegante
        plugins: { legend: { display: false } }
        }
        });
        });
    </script>
}