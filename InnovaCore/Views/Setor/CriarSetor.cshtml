@model InnovaCore.Domain.Entities.Setor

@{
    ViewData["Title"] = "Novo Setor";
    Layout = "_Layout";
}

<style>
    /* Seus estilos CSS permanecem iguais... */
    :root {
        --kanban-bg: #050505;
        --col-bg: #0d1117;
        --cyan-neon: #00e5ff;
        --card-bg: #161b22;
        --border-color: #30363d;
    }

    body {
        background-color: var(--kanban-bg) !important;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .form-container {
        max-width: 600px;
        margin: 50px auto;
        padding: 40px;
        background: var(--col-bg);
        border-radius: 25px;
        border: 1px solid var(--border-color);
        box-shadow: 0 0 30px rgba(0, 229, 255, 0.1);
    }

    .header-section h1 {
        font-weight: 900;
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 1.8rem;
    }

    .detail-label {
        color: var(--cyan-neon);
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 10px;
        display: block;
    }

    .form-control-dark {
        background: #050505;
        border: 1px solid #30363d;
        color: #fff;
        border-radius: 12px;
        padding: 15px;
        width: 100%;
        transition: all 0.3s;
    }

        .form-control-dark:focus {
            background: #050505;
            border-color: var(--cyan-neon);
            color: #fff;
            box-shadow: 0 0 10px var(--cyan-neon);
            outline: none;
        }

    .btn-neon-save {
        background: var(--cyan-neon);
        color: #000;
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 900;
        letter-spacing: 1px;
        transition: all 0.3s;
        width: 100%;
        margin-top: 20px;
        cursor: pointer;
    }

        .btn-neon-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 20px var(--cyan-neon);
            background: #fff;
        }

    .btn-back {
        color: #8b949e;
        text-decoration: none;
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 20px;
        transition: color 0.3s;
    }

        .btn-back:hover {
            color: var(--cyan-neon);
        }

    .swal-cyber-popup {
        border: 1px solid var(--border-color) !important;
        border-radius: 24px !important;
        background: var(--col-bg) !important;
    }
</style>

<div class="container">
    <div class="form-container">
        <a href="@Url.Action("Index", "Setor")" class="btn-back">
            <i class="bi bi-arrow-left"></i> VOLTAR PARA LISTAGEM
        </a>

        <div class="header-section mb-4">
            <h1>NOVO <span style="color:var(--cyan-neon)">SETOR</span></h1>
            <p class="text-white-50 small">Inicie um novo terminal de operações no sistema.</p>
        </div>

        <form id="formCriarSetor">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="detail-label">NOME DO SETOR</label>
                <input id="txtNomeSetor" class="form-control-dark" placeholder="Ex: Tecnologia, RH, Financeiro..." required />
            </div>

            @* Se você precisar do Email futuramente, descomente as linhas abaixo: *@
            @*
            <div class="mb-4">
                <label class="detail-label">EMAIL DO RESPONSÁVEL</label>
                <input id="txtEmailResponsavel" type="email" class="form-control-dark" placeholder="responsavel@empresa.com" required />
            </div>
            *@

            <div class="mt-2">
                <button type="submit" class="btn-neon-save">
                    CONFIRMAR CADASTRO
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('formCriarSetor').addEventListener('submit', function(e) {
        e.preventDefault();

        Swal.fire({
        title: 'Inicializar Terminal?',
        text: "O novo setor será integrado à rede operacional do sistema.",
        icon: 'question',
        showCancelButton: true,
        background: '#0d1117',
        color: '#fff',
        confirmButtonColor: '#00e5ff',
        cancelButtonColor: '#30363d',
        confirmButtonText: 'Confirmar',
        cancelButtonText: 'Cancelar',
        customClass: { popup: 'swal-cyber-popup' }
        }).then((result) => {
        if (result.isConfirmed) {
        Swal.fire({
        title: 'Alocando Recursos...',
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); },
        background: '#0d1117',
        color: '#fff',
        customClass: { popup: 'swal-cyber-popup' }
        });

        // CORREÇÃO: Removido o campo inexistente txtEmailResponsavel
        const payload = {
        Nome: document.getElementById('txtNomeSetor').value
        };

        fetch('@Url.Action("CriarSetor", "Setor")', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
        },
        body: JSON.stringify(payload)
        })
        .then(response => {
        if (!response.ok) {
        throw new Error('Erro na resposta do servidor (Status: ' + response.status + ')');
        }
        return response.json();
        })
        .then(data => {
        if(data.success) {
        Swal.fire({
        icon: 'success',
        title: 'Terminal Conectado',
        text: data.message,
        background: '#0d1117',
        color: '#fff',
        confirmButtonColor: '#00e5ff',
        customClass: { popup: 'swal-cyber-popup' }
        }).then(() => {
        window.location.href = data.redirectUrl;
        });
        } else {
        Swal.fire({ icon: 'error', title: 'Falha no Registro', text: data.message, background: '#0d1117', color: '#fff' });
        }
        })
        .catch((error) => {
        Swal.fire({
        icon: 'error',
        title: 'Erro de Conexão',
        text: error.message || 'Sem resposta da rede principal.',
        background: '#0d1117',
        color: '#fff'
        });
        });
        }
        });
        });
    </script>
}